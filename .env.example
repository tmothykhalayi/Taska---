# For local development with Vite proxy:
# Frontend will call /api/* and Vite forwards to this target.
VITE_API_PROXY_TARGET=http://localhost:8000

# Optional: set an explicit API base URL instead of proxy.
# Example (local backend): VITE_API_URL=http://localhost:8000
# Example (deployed backend): VITE_API_URL=https://healthcare-connect-dwg6.onrender.com
